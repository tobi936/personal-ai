OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://ollama:11434
CHROMA_HOST=http://chromadb:8000
SECRET_KEY=change-me-in-production

# --- Cloud-Modus (schnelles Testen, kein großes Ollama-Modell nötig) ---
#
# Option A: Nur Anthropic (Claude für LLM, Ollama für Embeddings)
# → Ollama lädt nur nomic-embed-text (~270 MB statt 2 GB)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option B: Nur OpenAI (LLM + Embeddings, kein Ollama nötig)
# OPENAI_API_KEY=sk-...
#
# Option C: Claude + OpenAI (empfohlen – schnellstes Setup ohne Ollama)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
#
# Priorität: ANTHROPIC_API_KEY > OPENAI_API_KEY > Ollama (lokaler Fallback)
