OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://ollama:11434
CHROMA_HOST=http://chromadb:8000
SECRET_KEY=change-me-in-production

# --- Ollama Cloud (schnelles Testen ohne großes lokales Modell) ---
# API-Key unter: https://ollama.com/settings/keys
# OLLAMA_API_KEY=your_key_here
# OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud
#
# Mit Cloud-Key: LLM läuft auf ollama.com, nur nomic-embed-text (~270 MB) wird lokal geladen
# Ohne Cloud-Key: alles lokal (OLLAMA_MODEL wird vollständig heruntergeladen)
